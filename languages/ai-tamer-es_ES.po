msgid "The User-Agent name of the licensed crawler."
msgstr "El nombre User-Agent del rastreador con licencia."

#: admin/views/licensing.php:127
msgid "Validity (days)"
msgstr "Validez (días)"

#: admin/views/licensing.php:135
msgid "Generate Token"
msgstr "Generar Token"

#: admin/views/licensing.php:140
msgid "How It Works"
msgstr "Cómo Funciona"

#: admin/views/licensing.php:142
msgid "You issue a signed HMAC token to a trusted AI company."
msgstr "Emitas un token HMAC firmado a una empresa de IA de confianza."

#: admin/views/licensing.php:143
msgid "They include it in every request as the X-AI-License-Token header."
msgstr "Ellos lo incluyen en cada petición como cabecera X-AI-License-Token."

#: admin/views/licensing.php:144
msgid "AI Tamer verifies the signature and bypasses blocking for that agent."
msgstr "AI Tamer verifica la firma y omite el bloqueo para ese agente."

#: admin/views/licensing.php:145
msgid "Tokens expire automatically after the configured period."
msgstr "Los tokens expiran automáticamente tras el periodo configurado."

#: admin/views/licensing.php:151
#, php-format
msgid ""
"JSON-LD schema.org/CreativeWork blocks and AI-Content-License HTTP headers "
"are automatically added to every page to signal your licensing intent to AI "
"crawlers. %s"
msgstr ""
"Bloques JSON-LD schema.org/CreativeWork y cabeceras HTTP AI-Content-License "
"se añaden automáticamente a cada página para señalar tu intención de "
"licencia a los rastreadores de IA. %s"

