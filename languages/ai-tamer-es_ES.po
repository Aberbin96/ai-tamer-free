#: admin/views/licensing.php:42
msgid ""
"Issue machine-readable license tokens to trusted AI agents. The agent must "
"send the token in the X-AI-License-Token HTTP header with each request to "
"bypass protection rules."
msgstr ""
"Emite tokens de licencia legibles por máquina a agentes de IA de confianza. "
"El agente debe enviar el token en la cabecera HTTP X-AI-License-Token con "
"cada petición para omitir las reglas de protección."

#: admin/views/licensing.php:47
msgid "Token revoked successfully."
msgstr "Token revocado con éxito."

#: admin/views/licensing.php:53
msgid "Token issued. Share it securely with the licensee."
msgstr "Token emitido. Compártelo de forma segura con el licenciatario."

#: admin/views/licensing.php:59
msgid "The agent sends this as: X-AI-License-Token: [token]"
msgstr "El agente lo envía como: X-AI-License-Token: [token]"

#: admin/views/licensing.php:65
msgid "Issued Tokens"
msgstr "Tokens Emitidos"

